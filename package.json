{
  "name": "blipp",
  "version": "0.8.191",
  "description": "",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vite build",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "kill:port": "npx kill-port 5174",
    "clean:pipeline:staging": "node scripts/clean-pipeline.mjs --staging",
    "clean:pipeline:staging:dry": "node scripts/clean-pipeline.mjs --staging --dry-run",
    "clean:pipeline:production": "node scripts/clean-pipeline.mjs --production",
    "clean:pipeline:production:dry": "node scripts/clean-pipeline.mjs --production --dry-run",
    "clean:stt-benchmark": "node scripts/clean-stt-benchmark.mjs",
    "clean:stt-benchmark:dry": "node scripts/clean-stt-benchmark.mjs --dry-run",
    "db:check": "npx tsx prisma/check-db.ts",
    "db:studio": "npx prisma studio",
    "build:ios": "vite build --mode staging && npx cap sync ios",
    "build:ios:production": "vite build --mode production && npx cap sync ios",
    "deploy": "vite build --mode staging && npx wrangler deploy",
    "deploy:production": "vite build --mode production && node scripts/patch-wrangler-env.mjs production && npx wrangler deploy",
    "deploy:quick": "npx wrangler deploy",
    "deploy:quick:production": "node scripts/patch-wrangler-env.mjs production && npx wrangler deploy",
    "db:push:staging": "powershell -Command \"Get-Content neon-config.env | ForEach-Object { if($_ -match '^STAGING_DATABASE_URL=(.+)$') { $env:DATABASE_URL=$matches[1] } }; npx prisma db push\"",
    "db:push:production": "powershell -Command \"Get-Content neon-config.env | ForEach-Object { if($_ -match '^PRODUCTION_DATABASE_URL=(.+)$') { $env:DATABASE_URL=$matches[1] } }; npx prisma db push\"",
    "db:push:staging:force": "powershell -Command \"Get-Content neon-config.env | ForEach-Object { if($_ -match '^STAGING_DATABASE_URL=(.+)$') { $env:DATABASE_URL=$matches[1] } }; npx prisma db push --accept-data-loss\"",
    "db:push:production:force": "powershell -Command \"Get-Content neon-config.env | ForEach-Object { if($_ -match '^PRODUCTION_DATABASE_URL=(.+)$') { $env:DATABASE_URL=$matches[1] } }; npx prisma db push --accept-data-loss\"",
    "tail:prod": "npx wrangler tail blipp",
    "apple:discover": "node scripts/apple-discover.mjs",
    "apple:discover:production": "node scripts/apple-discover.mjs --production",
    "apple:discover:dry": "node scripts/apple-discover.mjs --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boosey/blipp.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/boosey/blipp/issues"
  },
  "homepage": "https://github.com/boosey/blipp#readme",
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.2.0",
    "@capgo/capacitor-social-login": "^8.3.9",
    "@clerk/backend": "^2.32.2",
    "@clerk/clerk-react": "^5.61.2",
    "@clerk/shared": "^3.47.1",
    "@hono/clerk-auth": "^3.1.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fast-xml-parser": "^5.4.1",
    "hono": "^4.12.3",
    "lamejs": "^1.2.1",
    "lucide-react": "^0.575.0",
    "openai": "^6.25.0",
    "pg": "^8.19.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^2.2.2",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "stripe": "^20.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite-plugin-pwa": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.25.6",
    "@cloudflare/vitest-pool-workers": "^0.12.18",
    "@cloudflare/workers-types": "^4.20260226.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv": "^17.3.1",
    "jsdom": "^28.1.0",
    "prisma": "^7.4.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.69.0"
  }
}
