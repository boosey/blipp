# Production Secrets Template
# Copy this file: cp scripts/templates/secrets-production.env.template secrets-production.env
# Fill in values, then run: bash scripts/set-secrets.sh secrets-production.env --env production
# DELETE the file immediately after!

# Auth (Clerk Production instance)
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
# Set to "placeholder" initially — update after creating webhook endpoint in Phase 13
CLERK_WEBHOOK_SECRET=placeholder

# Billing (Stripe Live mode)
STRIPE_SECRET_KEY=sk_live_...
# Set to "placeholder" initially — update after creating webhook endpoint in Phase 13
STRIPE_WEBHOOK_SECRET=placeholder

# AI (same keys as staging, or separate for cost tracking)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Podcast data
PODCAST_INDEX_KEY=
PODCAST_INDEX_SECRET=

# Optional — uncomment and fill if you have these accounts
# GROQ_API_KEY=gsk_...
# DEEPGRAM_API_KEY=
# ASSEMBLYAI_API_KEY=
# GOOGLE_STT_API_KEY=
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
