# Staging Secrets Template
# Copy this file: cp scripts/templates/secrets-staging.env.template secrets-staging.env
# Fill in values, then run: bash scripts/set-secrets.sh secrets-staging.env
# DELETE the file immediately after!
#
# DO NOT add these here (they are NOT Worker secrets):
#   STRIPE_PUBLISHABLE_KEY — not used by the Worker
#   CLOUDFLARE_API_TOKEN — this is a GitHub Actions secret, not a Worker secret
#   VITE_* — these are build-time env vars set in GitHub Actions, not Worker secrets
#
# The authoritative list of Worker secrets is `worker/types.ts` (type Env).
# Keep this template in sync with that type.

# ── Auth (Clerk Development instance) ──
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
# Set to "placeholder" initially — update after creating webhook endpoint in Phase 10
CLERK_WEBHOOK_SECRET=placeholder

# ── Billing (Stripe) ──
# STRIPE_SECRET_KEY is set directly via wrangler secret put (not via this file)
# Set to "placeholder" initially — update after creating webhook endpoint in Phase 10
STRIPE_WEBHOOK_SECRET=placeholder

# ── Billing (RevenueCat — iOS IAP) ──
# Shared secret configured in RevenueCat dashboard → App → Webhooks → Authorization header
REVENUECAT_WEBHOOK_SECRET=
# REST API v2 secret key (sk_...) — used for server-side purchase verification
REVENUECAT_REST_API_KEY=
# Project ID (proj_...) — required in v2 REST URL paths
REVENUECAT_PROJECT_ID=

# ── AI (same keys as production — staging uses cheap models via PlatformConfig) ──
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Podcast data ──
PODCAST_INDEX_KEY=
PODCAST_INDEX_SECRET=

# ── Transactional email (ZeptoMail — welcome email queue) ──
# "Zoho-enczapikey" token value from ZeptoMail dashboard → Mail Agents → Send Mail API
# WITHOUT the "Zoho-enczapikey " prefix — just the token string itself
ZEPTOMAIL_TOKEN=
# Verified sender on ZeptoMail (e.g. welcome@podblipp.com)
ZEPTOMAIL_FROM_ADDRESS=welcome@podblipp.com
ZEPTOMAIL_FROM_NAME=Blipp
# Template key from ZeptoMail dashboard → Templates → <your welcome template>
ZEPTOMAIL_WELCOME_TEMPLATE_KEY=

# ── Service key encryption (DB-stored API keys) ──
# 64-char hex AES-256 master key — generate with: openssl rand -hex 32
# Must be the SAME value across restarts, or DB-stored keys become unrecoverable.
# Different value between staging and production is fine and recommended.
SERVICE_KEY_ENCRYPTION_KEY=

# ── Admin / infra tooling (optional but recommended) ──
# Neon API key — used by backup verification in admin UI
# NEON_API_KEY=
# NEON_PROJECT_ID=
# Cloudflare API token (Workers Observability scope) — used by admin Worker Logs viewer
# CF_API_TOKEN=
# CF_ACCOUNT_ID=
# GitHub PAT (repo + workflow scope) — used by admin "Refresh Apple catalog" button
# GITHUB_TOKEN=

# ── Optional AI providers ──
# GROQ_API_KEY=gsk_...
# DEEPGRAM_API_KEY=

# ── Optional web push (VAPID) ──
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
