generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "cloudflare"
}

generator scripts {
  provider = "prisma-client"
  output   = "../src/generated/prisma-node"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

// ── Plans ──

model Plan {
  id                      String   @id @default(cuid())
  name                    String                        // "Free", "Pro Monthly"
  slug                    String   @unique              // "free", "pro-monthly"
  description             String?                       // Marketing copy

  // ── Limits (null = unlimited) ──
  briefingsPerWeek        Int?                          // null = unlimited
  maxDurationMinutes      Int      @default(5)
  maxPodcastSubscriptions Int?                          // null = unlimited
  pastEpisodesLimit       Int?                          // null = unlimited, otherwise max past episodes available

  // ── Content Delivery ──
  transcriptAccess        Boolean  @default(false)      // view full source transcript alongside briefing
  dailyDigest             Boolean  @default(false)      // combined multi-podcast morning briefing

  // ── Pipeline & Processing ──
  concurrentPipelineJobs  Int      @default(1)          // max episodes processing simultaneously

  // ── Feature Flags ──
  adFree                  Boolean  @default(false)
  priorityProcessing      Boolean  @default(false)
  earlyAccess             Boolean  @default(false)

  // ── Personalization ──
  offlineAccess           Boolean  @default(false)      // mobile offline caching
  publicSharing           Boolean  @default(false)      // shareable briefing links

  // Billing — monthly
  priceCentsMonthly       Int      @default(0)          // 0 = free
  stripePriceIdMonthly    String?  @unique
  // Billing — annual
  priceCentsAnnual        Int?                          // null = no annual option
  stripePriceIdAnnual     String?  @unique
  // Shared Stripe
  stripeProductId         String?  @unique
  trialDays               Int      @default(0)

  // Voice Presets
  allowedVoicePresetIds   String[]                      // IDs of voice presets this plan grants access to (system default always available)

  // Display
  features                String[]                      // Marketing bullet points
  highlighted             Boolean  @default(false)
  active                  Boolean  @default(true)
  sortOrder               Int      @default(0)
  isDefault               Boolean  @default(false)      // Assigned to new users

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  users                   User[]
}

// ── Auth & Billing ──

model User {
  id                    String   @id @default(cuid())
  clerkId               String   @unique
  email                 String   @unique
  name                  String?
  imageUrl              String?
  stripeCustomerId      String?  @unique
  subscriptionEndsAt    DateTime?              // set when user cancels; subscription runs until this date
  planId                String
  isAdmin               Boolean  @default(false)
  status                String   @default("active")  // "active" | "suspended" | "banned"
  onboardingComplete    Boolean  @default(false)
  defaultDurationTier   Int      @default(5)
  defaultVoicePresetId  String?
  acceptAnyVoice        Boolean  @default(false)
  preferredCategories   String[]          // explicit interest categories for recommendations
  excludedCategories    String[]          // categories to never recommend
  preferredTopics       String[]          // free-text topic interests, e.g. ["AI", "NBA"]
  excludedTopics        String[]          // topics to suppress from recommendations
  zipCode               String?           // user-entered US zip code
  city                  String?           // resolved from zip code or Cloudflare cf.city
  state                 String?           // resolved from zip code or Cloudflare cf.region
  country               String?  @default("US")  // resolved from zip code or Cloudflare cf.country
  profileCompletedAt    DateTime?         // when user last saved interest preferences
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  plan                 Plan             @relation(fields: [planId], references: [id])
  defaultVoicePreset   VoicePreset?     @relation("defaultVoicePreset", fields: [defaultVoicePresetId], references: [id])
  subscriptions        Subscription[]
  briefings            Briefing[]
  feedItems            FeedItem[]
  briefingRequests     BriefingRequest[]
  apiKeys              ApiKey[]
  podcastRequests       PodcastRequest[]
  pushSubscriptions     PushSubscription[]
  podcastFavorites      PodcastFavorite[]
  podcastVotes          PodcastVote[]
  episodeVotes          EpisodeVote[]
  recommendationProfile     UserRecommendationProfile?
  recommendationCache       RecommendationCache?
  recommendationDismissals  RecommendationDismissal[]
  feedback                  Feedback[]
  blippFeedback             BlippFeedback[]
  listenOriginalEvents      ListenOriginalEvent[] @relation("ListenOriginalEvents")
  sportsTeams               UserSportsTeam[]
}

// ── Podcast Favorites (interest signals for recommendations) ──

model PodcastFavorite {
  id        String   @id @default(cuid())
  userId    String
  podcastId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@unique([userId, podcastId])
  @@index([userId])
}

// ── Votes (thumbs up/down) ──

model PodcastVote {
  id        String   @id @default(cuid())
  userId    String
  podcastId String
  vote      Int      // 1 = up, -1 = down
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@unique([userId, podcastId])
  @@index([podcastId])
}

model EpisodeVote {
  id        String   @id @default(cuid())
  userId    String
  episodeId String
  vote      Int      // 1 = up, -1 = down
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([episodeId])
}

// ── Push Notifications ──

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String                        // Public key
  auth       String                        // Auth secret
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Podcast & Episodes ──

model Podcast {
  id             String    @id @default(cuid())
  title          String
  description    String?
  feedUrl        String    @unique
  imageUrl       String?
  podcastIndexId String?   @unique
  appleId        String?   @unique
  author         String?
  language       String?
  categories     String[] // PostgreSQL array
  appleMetadata  Json?
  lastFetchedAt  DateTime?
  feedHealth     String?   // "excellent" | "good" | "fair" | "poor" | "broken"
  feedError      String?
  episodeCount   Int       @default(0)
  status         String    @default("active") // "active" | "paused" | "archived" | "pending_deletion" | "evicted"
  deliverable    Boolean   @default(true)     // false when no deliverable episodes exist
  geoProcessedAt DateTime?                     // null = not geo-processed yet
  appleRank          Int?      // Position in Apple Top 200 chart (1-200, null if unranked)
  piRank             Int?      // Best position across PI trending categories (1 = most trending). Updated each discovery run.
  lastDetailViewedAt DateTime? // Last time any user fetched this podcast's detail page
  source             String?   // "trending" | "user_request" | "manual"
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  episodes          Episode[]
  subscriptions     Subscription[]
  feedItems         FeedItem[]
  requests          PodcastRequest[]
  favorites         PodcastFavorite[]
  votes             PodcastVote[]
  podcastCategories          PodcastCategory[]
  profile                    PodcastProfile?
  geoProfiles                PodcastGeoProfile[]
  recommendationDismissals   RecommendationDismissal[]
}

model Episode {
  id              String        @id @default(cuid())
  podcastId       String
  title           String
  description     String?
  audioUrl        String
  publishedAt     DateTime?
  durationSeconds Int?
  guid            String
  transcriptUrl   String?
  contentStatus   ContentStatus @default(PENDING)
  transcriptR2Key String?
  audioR2Key      String?
  topicTags       String[]  // Extracted topic fingerprints from claims
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  podcast          Podcast             @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  distillation     Distillation?
  clips            Clip[]
  pipelineJobs     PipelineJob[]
  workProducts     WorkProduct[]
  feedItems        FeedItem[]
  votes            EpisodeVote[]
  benchmarkResults       SttBenchmarkResult[]
  claimsBenchmarkResults ClaimsBenchmarkResult[]
  blippFeedback          BlippFeedback[]
  listenOriginalEvents   ListenOriginalEvent[] @relation("ListenOriginalEvents")

  @@unique([podcastId, guid])
  @@index([podcastId, publishedAt])
}

enum ContentStatus {
  PENDING
  TRANSCRIPT_READY
  AUDIO_READY
  NOT_DELIVERABLE
}

// ── Distillation & Clips ──

model Distillation {
  id           String             @id @default(cuid())
  episodeId    String             @unique
  status       DistillationStatus @default(PENDING)
  transcript   String?
  claimsJson   Json? // Pass 1 output: scored claims
  errorMessage String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  clips   Clip[]
}

enum DistillationStatus {
  PENDING
  FETCHING_TRANSCRIPT
  TRANSCRIPT_READY
  EXTRACTING_CLAIMS
  COMPLETED
  FAILED
}

model Clip {
  id             String     @id @default(cuid())
  episodeId      String
  distillationId String
  durationTier   Int // 1, 2, 3, 5, 7, 10, 15, or 30 (minutes)
  status         ClipStatus @default(PENDING)
  narrativeText  String? // Pass 2 output: narrative for TTS
  wordCount      Int?
  audioKey         String? // R2 key: clips/{episodeId}/{durationTier}.mp3
  audioContentType String? // MIME type of stored audio (default: audio/mpeg)
  audioUrl         String? // Public R2 URL
  actualSeconds  Int? // Actual TTS audio duration
  errorMessage   String?
  voiceDegraded  Boolean    @default(false) // true when audio generated by non-primary TTS provider
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  voicePresetId  String?

  episode      Episode      @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  distillation Distillation @relation(fields: [distillationId], references: [id], onDelete: Cascade)
  voicePreset  VoicePreset? @relation(fields: [voicePresetId], references: [id])
  briefings    Briefing[]

  @@unique([episodeId, durationTier, voicePresetId])
}

// ── Briefings (per-user wrapper around a shared Clip) ──

model Briefing {
  id          String   @id @default(cuid())
  userId      String
  clipId      String
  adAudioUrl  String?  // personalized ad audio URL (null until ads ship)
  adAudioKey  String?  // R2 key for ad audio
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  clip      Clip       @relation(fields: [clipId], references: [id], onDelete: Cascade)
  feedItems FeedItem[]

  @@unique([userId, clipId])
}

enum ClipStatus {
  PENDING
  GENERATING_NARRATIVE
  GENERATING_AUDIO
  COMPLETED
  FAILED
}

// ── User Subscriptions ──

model Subscription {
  id            String   @id @default(cuid())
  userId        String
  podcastId     String
  durationTier  Int      // 1, 2, 3, 5, 7, 10, 15, or 30 (minutes)
  voicePresetId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  podcast     Podcast      @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  voicePreset VoicePreset? @relation(fields: [voicePresetId], references: [id])

  @@unique([userId, podcastId])
  @@index([userId])
}

// ── Feed Items ──

model FeedItem {
  id           String         @id @default(cuid())
  userId       String
  episodeId    String
  podcastId    String
  briefingId   String?
  durationTier Int
  source       FeedItemSource
  status       FeedItemStatus @default(PENDING)
  listened     Boolean        @default(false)
  listenedAt   DateTime?
  playbackPositionSeconds Float?
  requestId    String?
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode  Episode   @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  podcast  Podcast   @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  briefing Briefing? @relation(fields: [briefingId], references: [id])

  @@unique([userId, episodeId, durationTier])
  @@index([userId, status, createdAt])
  @@index([userId, listened, createdAt])
}

enum FeedItemSource {
  SUBSCRIPTION
  ON_DEMAND
  SHARED
}

enum FeedItemStatus {
  PENDING
  PROCESSING
  READY
  FAILED
  CANCELLED
}

// ── Admin: Pipeline Job Lifecycle ──

model PipelineJob {
  id             String            @id @default(cuid())
  requestId      String
  episodeId      String
  durationTier   Int               // from request item — source of truth
  voicePresetId  String?
  status         PipelineJobStatus @default(PENDING)
  currentStage   PipelineStage     @default(TRANSCRIPTION)
  distillationId String?
  clipId         String?
  errorMessage   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  completedAt    DateTime?
  dismissedAt    DateTime?

  request     BriefingRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  episode     Episode         @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  voicePreset VoicePreset?    @relation(fields: [voicePresetId], references: [id])
  steps       PipelineStep[]

  @@index([requestId, status])
}

enum PipelineStage {
  TRANSCRIPTION
  DISTILLATION
  CLIP_GENERATION // DEPRECATED: legacy value from pre-v2 pipeline. Kept for existing DB rows only.
  NARRATIVE_GENERATION
  AUDIO_GENERATION
  BRIEFING_ASSEMBLY
}

enum PipelineJobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  COMPLETED_DEGRADED // completed but used AI fallbacks (e.g. voice degraded)
  FAILED
  CANCELLED
}

model PipelineStep {
  id            String             @id @default(cuid())
  jobId         String
  stage         PipelineStage
  status        PipelineStepStatus @default(PENDING)
  cached        Boolean            @default(false)
  input         Json?
  output        Json?
  errorMessage  String?
  startedAt     DateTime?
  completedAt   DateTime?
  durationMs    Int?
  cost                Float?
  model               String?
  inputTokens         Int?
  outputTokens        Int?
  cacheCreationTokens Int?
  cacheReadTokens     Int?
  audioSeconds        Float?             // STT: input audio duration; TTS: output audio duration
  charCount           Int?               // TTS: input character count
  retryCount          Int                @default(0)
  workProductId String?
  createdAt     DateTime           @default(now())

  job         PipelineJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workProduct WorkProduct?   @relation(fields: [workProductId], references: [id])
  events      PipelineEvent[]
}

enum PipelineStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  FAILED
}

enum PipelineEventLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

// ── Briefing Requests (Demand-Driven Pipeline) ──

model BriefingRequest {
  id            String               @id @default(cuid())
  userId        String
  status        BriefingRequestStatus @default(PENDING)
  targetMinutes Int
  items         Json                 // BriefingRequestItem[]
  isTest        Boolean              @default(false)
  errorMessage  String?
  cancelledAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs PipelineJob[]
}

enum BriefingRequestStatus {
  PENDING
  PROCESSING
  CANCELLED
  COMPLETED
  COMPLETED_DEGRADED // completed but used AI fallbacks
  FAILED
}

// ── Work Products (Stage Outputs) ──

model WorkProduct {
  id           String          @id @default(cuid())
  type         WorkProductType
  episodeId    String?
  userId       String?
  durationTier Int?
  voice        String?         // TTS voice identifier, null = default
  r2Key        String          @unique
  sizeBytes    Int?
  metadata     Json?           // type-specific: { claimCount, wordCount, partial, etc. }
  createdAt    DateTime        @default(now())

  episode Episode?      @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  steps   PipelineStep[]
}

enum WorkProductType {
  TRANSCRIPT
  CLAIMS
  NARRATIVE
  AUDIO_CLIP
  BRIEFING_AUDIO
  SOURCE_AUDIO
}

model PipelineEvent {
  id        String             @id @default(cuid())
  stepId    String
  step      PipelineStep       @relation(fields: [stepId], references: [id], onDelete: Cascade)
  level     PipelineEventLevel
  message   String
  data      Json?
  createdAt DateTime           @default(now())

  @@index([stepId, createdAt])
}

// ── AI Service Error Tracking ──

model AiServiceError {
  id                String   @id @default(cuid())

  // Identity
  service           String                      // "stt" | "distillation" | "narrative" | "tts"
  provider          String                      // "anthropic", "openai", "groq", "deepgram", etc.
  model             String                      // model ID that was called
  operation         String                      // "transcribe", "complete", "synthesize"

  // Context
  correlationId     String                      // traces through the pipeline
  jobId             String?                     // PipelineJob reference
  stepId            String?                     // PipelineStep reference
  episodeId         String?

  // Error details
  category          String                      // rate_limit, timeout, auth, model_not_found, etc.
  severity          String                      // "transient" | "permanent"
  httpStatus        Int?
  errorMessage      String
  rawResponse       String?                     // first 2KB of error body (sanitized)

  // Timing
  requestDurationMs Int
  timestamp         DateTime @default(now())

  // Retry context
  retryCount        Int      @default(0)
  maxRetries        Int      @default(0)
  willRetry         Boolean  @default(false)
  resolved          Boolean  @default(false)    // true if a subsequent retry succeeded

  // Rate limit headers (when available)
  rateLimitRemaining Int?
  rateLimitResetAt   DateTime?

  createdAt         DateTime @default(now())

  @@index([service, provider, createdAt])
  @@index([correlationId])
  @@index([category, createdAt])
  @@index([episodeId])
  @@index([resolved, createdAt])
}

// ── Audit Log ──

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String                        // Clerk userId of the admin
  actorEmail String?                       // Denormalized for readability
  action     String                        // "config.update", "user.plan.change", "plan.create"
  entityType String                        // "PlatformConfig", "User", "Plan", "PipelineJob"
  entityId   String                        // ID of the affected record
  before     Json?                         // Snapshot before change
  after      Json?                         // Snapshot after change
  metadata   Json?                         // Extra context: { ip, userAgent }
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ── API Keys ──

model ApiKey {
  id         String    @id @default(cuid())
  name       String                        // "Monitoring", "Partner Feed"
  keyHash    String    @unique             // SHA-256 hash of the key
  keyPrefix  String                        // First 8 chars: "blp_live..."
  scopes     String[]                      // ["health:read", "feed:read"]
  userId     String                        // Admin who created it
  expiresAt  DateTime?                     // null = no expiry
  lastUsedAt DateTime?
  revokedAt  DateTime?                     // Soft revoke
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── STT Benchmark ──

model SttExperiment {
  id           String              @id @default(cuid())
  name         String
  status       SttExperimentStatus @default(PENDING)
  config       Json                // { models: string[], speeds: number[], episodeIds: string[] }
  totalTasks   Int                 @default(0)
  doneTasks    Int                 @default(0)
  errorMessage String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  completedAt  DateTime?
  results      SttBenchmarkResult[]
}

enum SttExperimentStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model SttBenchmarkResult {
  id              String   @id @default(cuid())
  experimentId    String
  episodeId       String
  model           String   // "whisper-1", "nova-2", "nova-3", "assemblyai-best", "google-chirp"
  provider        String?  // inference provider, e.g. "openai", "cloudflare", "deepgram"
  speed           Float    // 1.0, 1.5, 2.0
  status          String   @default("PENDING") // PENDING, RUNNING, POLLING, COMPLETED, FAILED
  costDollars     Float?
  latencyMs       Int?
  wer             Float?
  wordCount       Int?
  refWordCount    Int?
  r2AudioKey      String?  // sped-up audio in R2 (null for 1x)
  r2TranscriptKey    String?  // cleaned hypothesis text used in WER comparison
  r2RefTranscriptKey String?  // cleaned reference text used in WER comparison
  pollingId          String?  // external job ID for async APIs (AssemblyAI, Google)
  errorMessage    String?
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  experiment SttExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  episode    Episode       @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([experimentId, episodeId, model, provider, speed])
  @@index([experimentId])
}

// ── Claims Extraction Benchmark ──

enum ClaimsExperimentStatus {
  PENDING
  RUNNING
  JUDGING
  COMPLETED
  FAILED
  CANCELLED
}

model ClaimsExperiment {
  id                String                   @id @default(cuid())
  name              String
  status            ClaimsExperimentStatus   @default(PENDING)
  baselineModelId   String
  baselineProvider  String
  judgeModelId      String
  judgeProvider     String
  config            Json                     // { models: [{modelId, provider}], episodeIds: string[] }
  totalTasks        Int                      @default(0)
  doneTasks         Int                      @default(0)
  totalJudgeTasks   Int                      @default(0)
  doneJudgeTasks    Int                      @default(0)
  errorMessage      String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  completedAt       DateTime?
  results           ClaimsBenchmarkResult[]
}

model ClaimsBenchmarkResult {
  id                    String    @id @default(cuid())
  experimentId          String
  episodeId             String
  model                 String
  provider              String
  isBaseline            Boolean   @default(false)
  status                String    @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  claimCount            Int?
  inputTokens           Int?
  outputTokens          Int?
  costDollars           Float?
  latencyMs             Int?
  coverageScore         Float?    // 0-100, computed server-side from verdicts
  weightedCoverageScore Float?    // 0-100, importance-weighted
  hallucinations        Int?      // count from verdicts
  judgeStatus           String?   // PENDING, RUNNING, COMPLETED, FAILED (null for baseline)
  r2ClaimsKey           String?   // R2 key for full claims JSON
  r2JudgeKey            String?   // R2 key for per-claim verdicts JSON
  errorMessage          String?
  createdAt             DateTime  @default(now())
  completedAt           DateTime?

  experiment ClaimsExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  episode    Episode          @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([experimentId, episodeId, model, provider])
  @@index([experimentId])
}

// ── Podcast Requests (User-Submitted) ──

model PodcastRequest {
  id          String    @id @default(cuid())
  userId      String
  feedUrl     String
  title       String?
  imageUrl    String?
  status      String    @default("PENDING")  // PENDING, APPROVED, REJECTED, DUPLICATE
  podcastId   String?
  adminNote   String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  podcast Podcast? @relation(fields: [podcastId], references: [id])

  @@unique([userId, feedUrl])
  @@index([status])
}

// ── Admin: Runtime Configuration ──

model PlatformConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?  // admin clerkId who last updated
}

model PromptVersion {
  id        String   @id @default(cuid())
  stage     String   @default("")      // "distillation", "narrative" — groups all prompt keys for this stage
  version   Int
  label     String?
  values    Json     @default("{}")   // Record<promptKey, value> — all prompt values in this stage
  notes     String?
  createdAt DateTime @default(now())
  createdBy String?

  @@unique([stage, version])
  @@index([stage])
}

// ── Voice Presets ──

model VoicePreset {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String?
  isSystem      Boolean  @default(false)  // true = cannot be deleted
  isActive      Boolean  @default(true)
  config              Json     // { openai: { voice, instructions, speed }, groq: { voice }, cloudflare: {} }
  voiceCharacteristics Json?   // { gender, tone, pace } for future auto-matching
  createdAt           DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clips         Clip[]
  subscriptions Subscription[]
  users         User[]         @relation("defaultVoicePreset")
  pipelineJobs  PipelineJob[]
}

// ── AI Model Registry ──

enum AiStage {
  stt
  distillation
  narrative
  tts
  geoClassification
}

model AiModel {
  id        String    @id @default(cuid())
  stages    AiStage[] // pipeline stages this model is eligible for
  modelId   String    @unique // e.g. "whisper-1", "nova-3", "claude-sonnet-4-20250514"
  label     String    // e.g. "Whisper v1", "Deepgram Nova-3"
  developer String    // e.g. "openai", "deepgram", "anthropic"
  notes     String?   // capabilities, value notes, limitations
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  providers AiModelProvider[]
}

model AiModelProvider {
  id                   String    @id @default(cuid())
  aiModelId            String
  provider             String    // inference provider: "openai", "cloudflare", "groq", "deepgram", etc.
  providerModelId      String?   // provider-specific model ID, e.g. "@cf/openai/whisper" for Cloudflare
  providerLabel        String    // display name: "Cloudflare Workers AI"
  pricePerMinute       Float?    // STT / TTS per audio minute
  priceInputPerMToken  Float?    // LLM per 1M input tokens
  priceOutputPerMToken Float?    // LLM per 1M output tokens
  pricePerKChars       Float?    // TTS alt: per 1K characters
  isDefault            Boolean   @default(false)
  isAvailable          Boolean   @default(true)
  limits               Json?     // provider/model limits, e.g. { "maxFileSizeBytes": 26214400 }
  priceUpdatedAt       DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  model AiModel @relation(fields: [aiModelId], references: [id], onDelete: Cascade)

  @@unique([aiModelId, provider])
  @@index([aiModelId])
}

// ── Podcast Categories (Apple genre taxonomy) ──

model Category {
  id           String            @id @default(cuid())
  appleGenreId String            @unique
  name         String
  podcasts     PodcastCategory[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model PodcastCategory {
  podcastId  String
  categoryId String
  podcast    Podcast  @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([podcastId, categoryId])
}

// ── Recommendation Engine ──

model PodcastProfile {
  id              String   @id @default(cuid())
  podcastId       String   @unique
  categoryWeights Json     // { "Technology": 0.8, "Business": 0.3 }
  topicTags       String[] // Phase 2: topic fingerprinting
  popularity      Float    @default(0) // Normalized 0-1
  freshness       Float    @default(0) // Normalized 0-1
  subscriberCount Int      @default(0)
  embedding       Json?    // 768-dim float array from Workers AI
  computedAt      DateTime @default(now())
  podcast         Podcast  @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  @@index([computedAt])
}

model UserRecommendationProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  categoryWeights Json     // { "Technology": 0.9, "Science": 0.5 }
  topicTags       String[] // Phase 2
  listenCount     Int      @default(0)
  embedding       Json?    // 768-dim float array (centroid of subscribed podcasts)
  computedAt      DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecommendationCache {
  id         String   @id @default(cuid())
  userId     String   @unique
  podcasts   Json     // [{ podcastId, score, reasons: string[] }]
  computedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecommendationDismissal {
  id        String   @id @default(cuid())
  userId    String
  podcastId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@unique([userId, podcastId])
  @@index([userId])
}

// ── Scheduled Jobs ──

model CronJob {
  id                      String    @id @default(cuid())
  jobKey                  String    @unique
  label                   String
  description             String
  enabled                 Boolean   @default(true)
  intervalMinutes         Int
  defaultIntervalMinutes  Int
  lastRunAt               DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  runs CronRun[]
}

// ── Scheduled Job Runs ──

model CronRun {
  id           String        @id @default(cuid())
  jobKey       String
  job          CronJob?      @relation(fields: [jobKey], references: [jobKey])
  startedAt    DateTime      @default(now())
  completedAt  DateTime?
  durationMs   Int?
  status       CronRunStatus @default(IN_PROGRESS)
  result       Json?         // structured output: counts, summaries
  errorMessage String?

  logs CronRunLog[]

  @@index([jobKey, startedAt(sort: Desc)])
}

enum CronRunStatus {
  IN_PROGRESS
  SUCCESS
  FAILED
}

model CronRunLog {
  id        String          @id @default(cuid())
  runId     String
  run       CronRun         @relation(fields: [runId], references: [id], onDelete: Cascade)
  level     CronRunLogLevel
  message   String
  data      Json?
  timestamp DateTime        @default(now())

  @@index([runId, timestamp])
}

enum CronRunLogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

// ── Catalog Seed Jobs ──

model CatalogSeedJob {
  id                  String             @id @default(cuid())
  mode                String             @default("additive")
  source              String             @default("apple")   // "apple" | "podcast-index" | "manual"
  trigger             String             @default("admin")   // "admin" | "script" | "cron"
  status              String             @default("pending") // pending | discovering | upserting | complete | failed | cancelled
  podcastsDiscovered  Int                @default(0)
  error               String?
  archivedAt          DateTime?
  startedAt           DateTime           @default(now())
  completedAt         DateTime?
  errors              CatalogJobError[]

  @@index([status])
  @@index([startedAt])
  @@index([archivedAt])
}

model CatalogJobError {
  id         String          @id @default(cuid())
  jobId      String
  job        CatalogSeedJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  phase      String          // "discovery"
  message    String
  podcastId  String?
  episodeId  String?
  createdAt  DateTime        @default(now())

  @@index([jobId])
  @@index([jobId, phase])
}

// ── Episode Refresh Jobs ──

model EpisodeRefreshJob {
  id                       String                @id @default(cuid())
  scope                    String                @default("subscribed") // "subscribed" | "all" | "seed"
  trigger                  String                @default("admin")      // "admin" | "cron" | "seed"
  catalogSeedJobId         String?
  status                   String                @default("pending")    // pending | refreshing | paused | cancelled | complete | failed
  podcastsTotal            Int                   @default(0)
  podcastsCompleted        Int                   @default(0)
  podcastsWithNewEpisodes  Int                   @default(0)
  episodesDiscovered       Int                   @default(0)
  prefetchTotal            Int                   @default(0)
  prefetchCompleted        Int                   @default(0)
  error                    String?
  archivedAt               DateTime?
  startedAt                DateTime              @default(now())
  completedAt              DateTime?
  errors                   EpisodeRefreshError[]

  @@index([status])
  @@index([archivedAt])
}

model EpisodeRefreshError {
  id         String             @id @default(cuid())
  jobId      String
  job        EpisodeRefreshJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  phase      String             // "feed_scan" | "prefetch"
  message    String
  podcastId  String?
  episodeId  String?
  createdAt  DateTime           @default(now())

  @@index([jobId])
  @@index([jobId, phase])
}

// ── User Feedback ──

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ── Blipp Feedback (contextual per-episode feedback) ──

model BlippFeedback {
  id                 String   @id @default(cuid())
  userId             String
  episodeId          String
  briefingId         String?
  reasons            String[]
  message            String?
  isTechnicalFailure Boolean  @default(false)
  createdAt          DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([episodeId])
  @@index([createdAt])
  @@index([isTechnicalFailure, createdAt])
}

// ── Listen-to-Original Conversion Tracking ──

enum ListenOriginalEventType {
  listen_original_click
  listen_original_start
  listen_original_complete
}

enum DeviceType {
  mobile
  desktop
  tablet
}

enum AppPlatform {
  ios
  android
  web
}

enum ReferralSource {
  feed
  search
  share
  notification
}

model ListenOriginalEvent {
  id                    String                   @id @default(cuid())
  eventType             ListenOriginalEventType
  timestamp             DateTime                 @default(now())
  userId                String
  sessionId             String
  deviceType            DeviceType
  platform              AppPlatform
  blippId               String
  blippDurationMs       Int
  episodeId             String
  podcastId             String
  publisherId           String
  referralSource        ReferralSource
  timeToClickSec        Float
  blippCompletionPct    Float
  didReturnToBlipp      Boolean                  @default(false)
  utmSource             String?
  utmMedium             String?
  utmCampaign           String?
  reportBatchId         String?
  createdAt             DateTime                 @default(now())

  user    User    @relation("ListenOriginalEvents", fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation("ListenOriginalEvents", fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([publisherId, timestamp])
  @@index([userId, timestamp])
  @@index([blippId, eventType])
  @@index([episodeId, timestamp])
  @@index([reportBatchId])
}

model PublisherReportBatch {
  id             String   @id @default(cuid())
  publisherId    String
  periodStart    DateTime
  periodEnd      DateTime
  totalClicks    Int
  totalStarts    Int
  totalCompletes Int
  uniqueUsers    Int
  generatedAt    DateTime @default(now())

  @@index([publisherId, periodStart])
}

// ── Sports Teams & Markets ──

model SportsLeague {
  id        String           @id @default(cuid())
  name      String           @unique // "NFL", "NBA", "Premier League"
  sport     String           // "football", "basketball", "soccer"
  country   String?          // "us", "gb" — null for international
  divisions SportsDivision[]
  teams     SportsTeam[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model SportsDivision {
  id        String           @id @default(cuid())
  name      String           // "AFC", "AFC East", "Eastern Conference"
  leagueId  String
  parentId  String?
  league    SportsLeague     @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  parent    SportsDivision?  @relation("DivisionHierarchy", fields: [parentId], references: [id])
  children  SportsDivision[] @relation("DivisionHierarchy")
  teams     SportsTeam[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([leagueId, name])
}

model SportsTeam {
  id             String             @id @default(cuid())
  name           String             // "Kansas City Chiefs"
  city           String             // "Kansas City"
  nickname       String             // "Chiefs"
  abbreviation   String             // "KC"
  keywords       String[]           // title-match terms: ["Chiefs", "Kansas City Chiefs"]
  leagueId       String
  divisionId   String?
  league       SportsLeague       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  division     SportsDivision?    @relation(fields: [divisionId], references: [id])
  markets        SportsTeamMarket[]
  userSelections UserSportsTeam[]
  geoProfiles    PodcastGeoProfile[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([leagueId, abbreviation])
}

model SportsTeamMarket {
  id      String     @id @default(cuid())
  teamId  String
  city    String
  state   String
  team    SportsTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, city, state])
  @@index([city, state])
}

model UserSportsTeam {
  id        String     @id @default(cuid())
  userId    String
  teamId    String
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      SportsTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([userId])
}

model PodcastGeoProfile {
  id         String      @id @default(cuid())
  podcastId  String
  city       String      // city name (empty string for state-level matches)
  state      String      // full state name
  country    String      @default("US")
  scope      String      // "city" | "regional" | "state"
  teamId     String?     // links to SportsTeam if team-specific
  confidence Float       // 0-1
  source     String      // "keyword" | "llm"
  createdAt  DateTime    @default(now())

  podcast    Podcast     @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  team       SportsTeam? @relation(fields: [teamId], references: [id])

  @@unique([podcastId, city, state])
  @@index([city, state])
  @@index([podcastId])
}
