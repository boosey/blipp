generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "cloudflare"
}

generator scripts {
  provider = "prisma-client"
  output   = "../src/generated/prisma-node"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

// ── Plans ──

model Plan {
  id                      String   @id @default(cuid())
  name                    String                        // "Free", "Pro Monthly"
  slug                    String   @unique              // "free", "pro-monthly"
  description             String?                       // Marketing copy

  // Limits (null = unlimited)
  briefingsPerWeek        Int?                          // null = unlimited
  maxDurationMinutes      Int      @default(5)
  maxPodcastSubscriptions Int?                          // null = unlimited

  // Feature flags
  adFree                  Boolean  @default(false)
  priorityProcessing      Boolean  @default(false)
  earlyAccess             Boolean  @default(false)
  researchMode            Boolean  @default(false)
  crossPodcastSynthesis   Boolean  @default(false)

  // Billing — monthly
  priceCentsMonthly       Int      @default(0)          // 0 = free
  stripePriceIdMonthly    String?  @unique
  // Billing — annual
  priceCentsAnnual        Int?                          // null = no annual option
  stripePriceIdAnnual     String?  @unique
  // Shared Stripe
  stripeProductId         String?  @unique
  trialDays               Int      @default(0)

  // Display
  features                String[]                      // Marketing bullet points
  highlighted             Boolean  @default(false)
  active                  Boolean  @default(true)
  sortOrder               Int      @default(0)
  isDefault               Boolean  @default(false)      // Assigned to new users

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  users                   User[]
}

// ── Auth & Billing ──

model User {
  id                    String   @id @default(cuid())
  clerkId               String   @unique
  email                 String   @unique
  name                  String?
  imageUrl              String?
  stripeCustomerId      String?  @unique
  planId                String
  isAdmin               Boolean  @default(false)
  status                String   @default("active")  // "active" | "suspended" | "banned"
  onboardingComplete    Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  plan             Plan             @relation(fields: [planId], references: [id])
  subscriptions    Subscription[]
  briefings        Briefing[]
  feedItems        FeedItem[]
  briefingRequests BriefingRequest[]
  apiKeys          ApiKey[]
  podcastRequests   PodcastRequest[]
  pushSubscriptions PushSubscription[]
  podcastFavorites  PodcastFavorite[]
}

// ── Podcast Favorites (interest signals for recommendations) ──

model PodcastFavorite {
  id        String   @id @default(cuid())
  userId    String
  podcastId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@unique([userId, podcastId])
  @@index([userId])
}

// ── Push Notifications ──

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String                        // Public key
  auth       String                        // Auth secret
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Podcast & Episodes ──

model Podcast {
  id             String    @id @default(cuid())
  title          String
  description    String?
  feedUrl        String    @unique
  imageUrl       String?
  podcastIndexId String?   @unique
  appleId        String?   @unique
  author         String?
  language       String?
  categories     String[] // PostgreSQL array
  appleMetadata  Json?
  lastFetchedAt  DateTime?
  feedHealth     String?   // "excellent" | "good" | "fair" | "poor" | "broken"
  feedError      String?
  episodeCount   Int       @default(0)
  status         String    @default("active") // "active" | "paused" | "archived"
  source         String?   // "trending" | "user_request" | "manual"
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  episodes          Episode[]
  subscriptions     Subscription[]
  feedItems         FeedItem[]
  requests          PodcastRequest[]
  favorites         PodcastFavorite[]
  podcastCategories PodcastCategory[]
}

model Episode {
  id              String        @id @default(cuid())
  podcastId       String
  title           String
  description     String?
  audioUrl        String
  publishedAt     DateTime
  durationSeconds Int?
  guid            String
  transcriptUrl   String?
  contentStatus   ContentStatus @default(PENDING)
  transcriptR2Key String?
  audioR2Key      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  podcast          Podcast             @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  distillation     Distillation?
  clips            Clip[]
  pipelineJobs     PipelineJob[]
  workProducts     WorkProduct[]
  feedItems        FeedItem[]
  benchmarkResults SttBenchmarkResult[]

  @@unique([podcastId, guid])
  @@index([podcastId, publishedAt])
}

enum ContentStatus {
  PENDING
  TRANSCRIPT_READY
  AUDIO_READY
  NOT_DELIVERABLE
}

// ── Distillation & Clips ──

model Distillation {
  id           String             @id @default(cuid())
  episodeId    String             @unique
  status       DistillationStatus @default(PENDING)
  transcript   String?
  claimsJson   Json? // Pass 1 output: scored claims
  errorMessage String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  clips   Clip[]
}

enum DistillationStatus {
  PENDING
  FETCHING_TRANSCRIPT
  TRANSCRIPT_READY
  EXTRACTING_CLAIMS
  COMPLETED
  FAILED
}

model Clip {
  id             String     @id @default(cuid())
  episodeId      String
  distillationId String
  durationTier   Int // 1, 2, 3, 5, 7, 10, 15, or 30 (minutes)
  status         ClipStatus @default(PENDING)
  narrativeText  String? // Pass 2 output: narrative for TTS
  wordCount      Int?
  audioKey       String? // R2 key: clips/{episodeId}/{durationTier}.mp3
  audioUrl       String? // Public R2 URL
  actualSeconds  Int? // Actual TTS audio duration
  errorMessage   String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  episode      Episode      @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  distillation Distillation @relation(fields: [distillationId], references: [id], onDelete: Cascade)
  briefings    Briefing[]

  @@unique([episodeId, durationTier])
}

// ── Briefings (per-user wrapper around a shared Clip) ──

model Briefing {
  id          String   @id @default(cuid())
  userId      String
  clipId      String
  adAudioUrl  String?  // personalized ad audio URL (null until ads ship)
  adAudioKey  String?  // R2 key for ad audio
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  clip      Clip       @relation(fields: [clipId], references: [id], onDelete: Cascade)
  feedItems FeedItem[]

  @@unique([userId, clipId])
}

enum ClipStatus {
  PENDING
  GENERATING_NARRATIVE
  GENERATING_AUDIO
  COMPLETED
  FAILED
}

// ── User Subscriptions ──

model Subscription {
  id           String   @id @default(cuid())
  userId       String
  podcastId    String
  durationTier Int      // 1, 2, 3, 5, 7, 10, 15, or 30 (minutes)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@unique([userId, podcastId])
  @@index([userId])
}

// ── Feed Items ──

model FeedItem {
  id           String         @id @default(cuid())
  userId       String
  episodeId    String
  podcastId    String
  briefingId   String?
  durationTier Int
  source       FeedItemSource
  status       FeedItemStatus @default(PENDING)
  listened     Boolean        @default(false)
  listenedAt   DateTime?
  requestId    String?
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode  Episode   @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  podcast  Podcast   @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  briefing Briefing? @relation(fields: [briefingId], references: [id])

  @@unique([userId, episodeId, durationTier])
  @@index([userId, status, createdAt])
  @@index([userId, listened, createdAt])
}

enum FeedItemSource {
  SUBSCRIPTION
  ON_DEMAND
}

enum FeedItemStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

// ── Admin: Pipeline Job Lifecycle ──

model PipelineJob {
  id             String            @id @default(cuid())
  requestId      String
  episodeId      String
  durationTier   Int               // from request item — source of truth
  status         PipelineJobStatus @default(PENDING)
  currentStage   PipelineStage     @default(TRANSCRIPTION)
  distillationId String?
  clipId         String?
  errorMessage   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  completedAt    DateTime?

  request  BriefingRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  episode  Episode         @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  steps    PipelineStep[]

  @@index([requestId, status])
}

enum PipelineStage {
  TRANSCRIPTION
  DISTILLATION
  CLIP_GENERATION // DEPRECATED: legacy value from pre-v2 pipeline. Kept for existing DB rows only.
  NARRATIVE_GENERATION
  AUDIO_GENERATION
  BRIEFING_ASSEMBLY
}

enum PipelineJobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model PipelineStep {
  id            String             @id @default(cuid())
  jobId         String
  stage         PipelineStage
  status        PipelineStepStatus @default(PENDING)
  cached        Boolean            @default(false)
  input         Json?
  output        Json?
  errorMessage  String?
  startedAt     DateTime?
  completedAt   DateTime?
  durationMs    Int?
  cost          Float?
  model         String?
  inputTokens   Int?
  outputTokens  Int?
  retryCount    Int                @default(0)
  workProductId String?
  createdAt     DateTime           @default(now())

  job         PipelineJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workProduct WorkProduct?   @relation(fields: [workProductId], references: [id])
  events      PipelineEvent[]
}

enum PipelineStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  FAILED
}

enum PipelineEventLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

// ── Briefing Requests (Demand-Driven Pipeline) ──

model BriefingRequest {
  id            String               @id @default(cuid())
  userId        String
  status        BriefingRequestStatus @default(PENDING)
  targetMinutes Int
  items         Json                 // BriefingRequestItem[]
  isTest        Boolean              @default(false)
  errorMessage  String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs PipelineJob[]
}

enum BriefingRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ── Work Products (Stage Outputs) ──

model WorkProduct {
  id           String          @id @default(cuid())
  type         WorkProductType
  episodeId    String?
  userId       String?
  durationTier Int?
  voice        String?         // TTS voice identifier, null = default
  r2Key        String          @unique
  sizeBytes    Int?
  metadata     Json?           // type-specific: { claimCount, wordCount, partial, etc. }
  createdAt    DateTime        @default(now())

  episode Episode?      @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  steps   PipelineStep[]
}

enum WorkProductType {
  TRANSCRIPT
  CLAIMS
  NARRATIVE
  AUDIO_CLIP
  BRIEFING_AUDIO
}

model PipelineEvent {
  id        String             @id @default(cuid())
  stepId    String
  step      PipelineStep       @relation(fields: [stepId], references: [id], onDelete: Cascade)
  level     PipelineEventLevel
  message   String
  data      Json?
  createdAt DateTime           @default(now())

  @@index([stepId, createdAt])
}

// ── AI Service Error Tracking ──

model AiServiceError {
  id                String   @id @default(cuid())

  // Identity
  service           String                      // "stt" | "distillation" | "narrative" | "tts"
  provider          String                      // "anthropic", "openai", "groq", "deepgram", etc.
  model             String                      // model ID that was called
  operation         String                      // "transcribe", "complete", "synthesize"

  // Context
  correlationId     String                      // traces through the pipeline
  jobId             String?                     // PipelineJob reference
  stepId            String?                     // PipelineStep reference
  episodeId         String?

  // Error details
  category          String                      // rate_limit, timeout, auth, model_not_found, etc.
  severity          String                      // "transient" | "permanent"
  httpStatus        Int?
  errorMessage      String
  rawResponse       String?                     // first 2KB of error body (sanitized)

  // Timing
  requestDurationMs Int
  timestamp         DateTime @default(now())

  // Retry context
  retryCount        Int      @default(0)
  maxRetries        Int      @default(0)
  willRetry         Boolean  @default(false)
  resolved          Boolean  @default(false)    // true if a subsequent retry succeeded

  // Rate limit headers (when available)
  rateLimitRemaining Int?
  rateLimitResetAt   DateTime?

  createdAt         DateTime @default(now())

  @@index([service, provider, createdAt])
  @@index([correlationId])
  @@index([category, createdAt])
  @@index([episodeId])
  @@index([resolved, createdAt])
}

// ── Audit Log ──

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String                        // Clerk userId of the admin
  actorEmail String?                       // Denormalized for readability
  action     String                        // "config.update", "user.plan.change", "plan.create"
  entityType String                        // "PlatformConfig", "User", "Plan", "PipelineJob"
  entityId   String                        // ID of the affected record
  before     Json?                         // Snapshot before change
  after      Json?                         // Snapshot after change
  metadata   Json?                         // Extra context: { ip, userAgent }
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ── API Keys ──

model ApiKey {
  id         String    @id @default(cuid())
  name       String                        // "Monitoring", "Partner Feed"
  keyHash    String    @unique             // SHA-256 hash of the key
  keyPrefix  String                        // First 8 chars: "blp_live..."
  scopes     String[]                      // ["health:read", "feed:read"]
  userId     String                        // Admin who created it
  expiresAt  DateTime?                     // null = no expiry
  lastUsedAt DateTime?
  revokedAt  DateTime?                     // Soft revoke
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── STT Benchmark ──

model SttExperiment {
  id           String              @id @default(cuid())
  name         String
  status       SttExperimentStatus @default(PENDING)
  config       Json                // { models: string[], speeds: number[], episodeIds: string[] }
  totalTasks   Int                 @default(0)
  doneTasks    Int                 @default(0)
  errorMessage String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  completedAt  DateTime?
  results      SttBenchmarkResult[]
}

enum SttExperimentStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model SttBenchmarkResult {
  id              String   @id @default(cuid())
  experimentId    String
  episodeId       String
  model           String   // "whisper-1", "nova-2", "nova-3", "assemblyai-best", "google-chirp"
  provider        String?  // inference provider, e.g. "openai", "cloudflare", "deepgram"
  speed           Float    // 1.0, 1.5, 2.0
  status          String   @default("PENDING") // PENDING, RUNNING, POLLING, COMPLETED, FAILED
  costDollars     Float?
  latencyMs       Int?
  wer             Float?
  wordCount       Int?
  refWordCount    Int?
  r2AudioKey      String?  // sped-up audio in R2 (null for 1x)
  r2TranscriptKey    String?  // cleaned hypothesis text used in WER comparison
  r2RefTranscriptKey String?  // cleaned reference text used in WER comparison
  pollingId          String?  // external job ID for async APIs (AssemblyAI, Google)
  errorMessage    String?
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  experiment SttExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  episode    Episode       @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([experimentId, episodeId, model, provider, speed])
  @@index([experimentId])
}

// ── Podcast Requests (User-Submitted) ──

model PodcastRequest {
  id          String    @id @default(cuid())
  userId      String
  feedUrl     String
  title       String?
  imageUrl    String?
  status      String    @default("PENDING")  // PENDING, APPROVED, REJECTED, DUPLICATE
  podcastId   String?
  adminNote   String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  podcast Podcast? @relation(fields: [podcastId], references: [id])

  @@unique([userId, feedUrl])
  @@index([status])
}

// ── Admin: Runtime Configuration ──

model PlatformConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?  // admin clerkId who last updated
}

// ── AI Model Registry ──

enum AiStage {
  stt
  distillation
  narrative
  tts
}

model AiModel {
  id        String    @id @default(cuid())
  stage     AiStage
  modelId   String    // e.g. "whisper-1", "nova-3", "claude-sonnet-4-20250514"
  label     String    // e.g. "Whisper v1", "Deepgram Nova-3"
  developer String    // e.g. "openai", "deepgram", "anthropic"
  notes     String?   // capabilities, value notes, limitations
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  providers AiModelProvider[]

  @@unique([stage, modelId])
}

model AiModelProvider {
  id                   String    @id @default(cuid())
  aiModelId            String
  provider             String    // inference provider: "openai", "cloudflare", "groq", "deepgram", etc.
  providerModelId      String?   // provider-specific model ID, e.g. "@cf/openai/whisper" for Cloudflare
  providerLabel        String    // display name: "Cloudflare Workers AI"
  pricePerMinute       Float?    // STT / TTS per audio minute
  priceInputPerMToken  Float?    // LLM per 1M input tokens
  priceOutputPerMToken Float?    // LLM per 1M output tokens
  pricePerKChars       Float?    // TTS alt: per 1K characters
  isDefault            Boolean   @default(false)
  isAvailable          Boolean   @default(true)
  priceUpdatedAt       DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  model AiModel @relation(fields: [aiModelId], references: [id], onDelete: Cascade)

  @@unique([aiModelId, provider])
  @@index([aiModelId])
}

// ── Podcast Categories (Apple genre taxonomy) ──

model Category {
  id           String            @id @default(cuid())
  appleGenreId String            @unique
  name         String
  podcasts     PodcastCategory[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model PodcastCategory {
  podcastId  String
  categoryId String
  podcast    Podcast  @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([podcastId, categoryId])
}
